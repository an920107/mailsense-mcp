{
  "db_name": "PostgreSQL",
  "query": "\n            UPDATE tasks\n            SET status = 'InProgress', updated_at = NOW()\n            WHERE id = (\n                SELECT id FROM tasks\n                WHERE status = 'Pending'\n                ORDER BY created_at ASC\n                LIMIT 1\n                FOR UPDATE SKIP LOCKED\n            )\n            RETURNING id, task_type, status, payload, created_at, updated_at\n            ",
